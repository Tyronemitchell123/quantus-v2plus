# Example environment configuration for quantus-pulse
# Rename this file to `.env` and fill in all production secrets before deploying or running locally.
# Documentation: Each section groups secrets by provider/function.

# ─── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=             # Your Supabase project URL (https://xxxx.supabase.co)
SUPABASE_ANON_KEY=        # Supabase anon (public) API key (frontend access)
SUPABASE_SERVICE_ROLE_KEY=# Supabase service role (private) API key (backend only)

# ─── PostgreSQL / Railway ────────────────────────────────────────
DATABASE_URL=             # PostgreSQL connection string (if not using only Supabase)

# ─── Stripe Payments ─────────────────────────────────────────────
STRIPE_SECRET_KEY=        # Stripe secret key (sk_live_...)
STRIPE_CONNECT_WEBHOOK_SECRET= # Stripe Connect webhook signing secret (whsec_...)

# ─── TrueLayer Payments (optional) ───────────────────────────────
TRUELAYER_CLIENT_ID=      # TrueLayer client ID
TRUELAYER_CLIENT_SECRET=  # TrueLayer client secret
TRUELAYER_SIGNING_KEY_ID= # TrueLayer signing key
TRUELAYER_SIGNING_PRIVATE_KEY= # TrueLayer signing private key (PEM)
TRUELAYER_SIGNING_PUBLIC_KEY=  # TrueLayer signing public key (PEM)

# ─── Lovable AI (optional) ───────────────────────────────────────
LOVABLE_API_KEY=          # Lovable AI model API key

# ─── Firecrawl Web Scraping (optional) ───────────────────────────
FIRECRAWL_API_KEY=        # Firecrawl scraping/enrichment API key

# ─── Resend Email (optional) ─────────────────────────────────────
RESEND_API_KEY=           # Transactional/notification email delivery

# ─── AWS (optional, for quantum jobs) ────────────────────────────
AWS_ACCESS_KEY_ID=        # Braket/quatum-compute access key
AWS_SECRET_ACCESS_KEY=    # Braket/quantum-compute secret
AWS_REGION=               # AWS region (e.g. eu-west-1)

# ─── Other / Platform ─────────────────────────────────────────---
# Add any other integration, webhook, or 3rd party keys below as needed

